{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Report Section Draft Output",
  "description": "Saída estruturada para minuta de seção de laudo pericial gerada por IA e sujeita a revisão humana.",
  "type": "object",
  "required": [
    "section_title",
    "draft_text",
    "evidence_references",
    "technical_basis",
    "limitations",
    "confidence",
    "requires_human_review",
    "safety_flags"
  ],
  "additionalProperties": false,
  "properties": {
    "section_title": {
      "type": "string",
      "minLength": 1,
      "description": "Título da seção de laudo."
    },
    "draft_text": {
      "type": "string",
      "minLength": 1,
      "description": "Minuta da seção em linguagem técnica, neutra e revisável."
    },
    "evidence_references": {
      "type": "array",
      "description": "Evidências efetivamente usadas na minuta.",
      "items": {
        "type": "object",
        "required": ["reference_id", "description", "validation_status", "usage"],
        "additionalProperties": false,
        "properties": {
          "reference_id": {
            "type": "string",
            "description": "ID, documento/página ou referência fornecida no contexto."
          },
          "description": {
            "type": "string",
            "description": "Descrição breve da evidência."
          },
          "validation_status": {
            "type": "string",
            "enum": ["validated", "pending", "rejected", "unknown"],
            "description": "Status de validação informado ou unknown quando ausente."
          },
          "usage": {
            "type": "string",
            "description": "Como a evidência foi usada na análise."
          }
        }
      }
    },
    "technical_basis": {
      "type": "object",
      "required": ["methodology", "findings", "assumptions"],
      "additionalProperties": false,
      "properties": {
        "methodology": {
          "type": "string",
          "description": "Metodologia técnica aplicada, restrita ao contexto fornecido."
        },
        "findings": {
          "type": "array",
          "description": "Achados técnicos considerados na minuta.",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "description": "Premissas explicitamente fornecidas pelo usuário/sistema. Não incluir premissas inventadas.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "description": "Limitações, lacunas documentais, baixa confiança ou ressalvas relevantes.",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "object",
      "required": ["level", "justification"],
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Nível de confiança da minuta, considerando qualidade e validação das evidências."
        },
        "justification": {
          "type": "string",
          "description": "Justificativa objetiva para o nível de confiança."
        }
      }
    },
    "requires_human_review": {
      "type": "boolean",
      "const": true,
      "description": "Sempre true. Minutas exigem revisão humana."
    },
    "safety_flags": {
      "type": "array",
      "description": "Alertas de segurança, escopo ou rastreabilidade.",
      "items": {
        "type": "object",
        "required": ["type", "message"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "missing_evidence",
              "unvalidated_evidence",
              "contradiction",
              "scope_limit",
              "legal_merit_risk",
              "none"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
