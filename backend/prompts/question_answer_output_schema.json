{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Preliminary Answer to Forensic Accounting Question",
  "description": "Schema for preliminary answers generated by AI to quesitos (questions) in forensic accounting cases",
  "type": "object",
  "required": [
    "question_id",
    "question_text",
    "question_theme",
    "direct_findings",
    "technical_analysis",
    "relevant_context",
    "preliminary_conclusion",
    "confidence_level",
    "confidence_justification",
    "evidence_referenced",
    "limitations_and_caveats"
  ],
  "properties": {
    "question_id": {
      "type": "string",
      "description": "UUID of the quesito being answered"
    },
    "question_text": {
      "type": "string",
      "description": "The original question text"
    },
    "question_theme": {
      "type": "string",
      "enum": ["contábil", "financeiro", "trabalhista", "outro"],
      "description": "Theme/subject matter of the question"
    },
    "question_type": {
      "type": "string",
      "enum": ["técnico", "jurídico", "complementar", "outro"],
      "description": "Type of question"
    },
    "analysis_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the analysis was generated"
    },
    "direct_findings": {
      "type": "object",
      "required": ["findings", "evidence_base"],
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["finding", "evidence_reference", "document_type", "specificity"],
            "properties": {
              "finding": {
                "type": "string",
                "description": "A specific factual finding from the evidence"
              },
              "evidence_reference": {
                "type": "string",
                "description": "Reference to the evidence item (document, page, section)"
              },
              "document_type": {
                "type": "string",
                "description": "Type of document referenced (e.g., bank statement, contract, payroll)"
              },
              "specificity": {
                "type": "string",
                "description": "Specific amounts, dates, accounts, or details from evidence"
              }
            }
          },
          "description": "Array of factual findings directly from documents"
        },
        "evidence_base": {
          "type": "string",
          "description": "Summary of evidence types and volume reviewed"
        }
      }
    },
    "technical_analysis": {
      "type": "object",
      "required": ["analysis_type", "methodology", "key_calculations", "analysis_results"],
      "properties": {
        "analysis_type": {
          "type": "string",
          "enum": ["account_analysis", "financial_ratios", "cash_flow_analysis", "salary_verification", "reconciliation", "trend_analysis", "other"],
          "description": "Type of technical analysis performed"
        },
        "methodology": {
          "type": "string",
          "description": "Description of analytical methodology used"
        },
        "key_calculations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["calculation", "formula", "result", "source"],
            "properties": {
              "calculation": {
                "type": "string",
                "description": "Description of what was calculated"
              },
              "formula": {
                "type": "string",
                "description": "The formula or methodology used"
              },
              "result": {
                "type": "string",
                "description": "The calculated result with units"
              },
              "source": {
                "type": "string",
                "description": "References to source documents/evidence"
              }
            }
          },
          "description": "Array of calculations with formulas and results"
        },
        "analysis_results": {
          "type": "string",
          "description": "Summary of analytical findings and patterns identified"
        }
      }
    },
    "relevant_context": {
      "type": "object",
      "required": ["applicable_standards", "relevant_rules", "contextual_factors"],
      "properties": {
        "applicable_standards": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Accounting standards, IFRS, GAAP, or Brazilian norms applicable to the question"
        },
        "relevant_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Labor laws, tax rules, or other regulations relevant to the question"
        },
        "contextual_factors": {
          "type": "string",
          "description": "Business context, market conditions, or other factors relevant to interpretation"
        }
      }
    },
    "preliminary_conclusion": {
      "type": "object",
      "required": ["answer", "reasoning", "evidence_support"],
      "properties": {
        "answer": {
          "type": "string",
          "description": "The direct answer to the question"
        },
        "reasoning": {
          "type": "string",
          "description": "Logical reasoning connecting findings to conclusion"
        },
        "evidence_support": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["evidence_item", "how_supports_conclusion"],
            "properties": {
              "evidence_item": {
                "type": "string",
                "description": "Specific evidence item"
              },
              "how_supports_conclusion": {
                "type": "string",
                "description": "How this evidence supports the conclusion"
              }
            }
          },
          "description": "Evidence items and how they support the conclusion"
        }
      }
    },
    "confidence_level": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence level (0-1) where 1 is completely certain, 0 is highly uncertain"
    },
    "confidence_justification": {
      "type": "object",
      "required": ["basis", "limitations", "certainty_factors"],
      "properties": {
        "basis": {
          "type": "string",
          "description": "Why this confidence level is justified"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Factors that limit certainty"
        },
        "certainty_factors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Factors that increase certainty"
        }
      }
    },
    "evidence_referenced": {
      "type": "object",
      "required": ["total_evidence_items", "evidence_items", "evidence_gaps"],
      "properties": {
        "total_evidence_items": {
          "type": "integer",
          "description": "Total number of evidence items reviewed"
        },
        "evidence_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["evidence_id", "document_type", "date_range", "relevance"],
            "properties": {
              "evidence_id": {
                "type": "string",
                "description": "UUID or ID of evidence item"
              },
              "document_type": {
                "type": "string",
                "description": "Type of document (e.g., bank statement, contract, payroll)"
              },
              "date_range": {
                "type": "string",
                "description": "Date range covered by document"
              },
              "relevance": {
                "type": "string",
                "enum": ["primary", "supporting", "contextual"],
                "description": "How relevant this evidence is to answering the question"
              },
              "usage": {
                "type": "string",
                "description": "How this evidence was used in the analysis"
              }
            }
          },
          "description": "List of evidence items reviewed"
        },
        "evidence_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Documents or evidence that would strengthen the analysis but are not available"
        }
      }
    },
    "limitations_and_caveats": {
      "type": "object",
      "required": ["data_limitations", "analytical_limitations", "assumptions", "recommendations"],
      "properties": {
        "data_limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Missing data or incomplete evidence"
        },
        "analytical_limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Limitations in what can be concluded from available evidence"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assumption", "justification"],
            "properties": {
              "assumption": {
                "type": "string",
                "description": "An assumption made in the analysis"
              },
              "justification": {
                "type": "string",
                "description": "Why this assumption was necessary"
              }
            }
          },
          "description": "Assumptions made in the analysis"
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional evidence or analysis that would strengthen conclusions"
        }
      }
    },
    "quality_indicators": {
      "type": "object",
      "required": ["completeness", "evidence_coverage", "technical_soundness"],
      "properties": {
        "completeness": {
          "type": "string",
          "enum": ["complete", "substantial", "partial", "insufficient"],
          "description": "Does the answer fully address the question?"
        },
        "evidence_coverage": {
          "type": "string",
          "enum": ["comprehensive", "adequate", "limited", "minimal"],
          "description": "How well is the answer supported by evidence?"
        },
        "technical_soundness": {
          "type": "string",
          "enum": ["sound", "reasonable", "questionable", "problematic"],
          "description": "Is the technical analysis methodologically sound?"
        }
      }
    }
  }
}
