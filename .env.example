# ============================================================
# OfficeJoe — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# NUNCA versione o arquivo .env.
# ============================================================

# ── Aplicação ─────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
APP_SECRET_KEY=TROQUE_POR_STRING_ALEATORIA_DE_64_CHARS_MINIMO
APP_DEBUG=false
APP_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=officejoe
POSTGRES_USER=officejoe_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
DATABASE_URL=postgresql+asyncpg://officejoe_user:TROQUE_POR_SENHA_FORTE@db:5432/officejoe

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=TROQUE_POR_ACCESS_KEY
MINIO_SECRET_KEY=TROQUE_POR_SECRET_KEY_12CHARS_MIN
MINIO_BUCKET_DOCUMENTS=officejoe-documents
MINIO_SECURE=false
