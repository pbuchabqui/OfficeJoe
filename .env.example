# ============================================================
# OfficeJoe – Plataforma de Perícias Contábeis
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env.
# ============================================================

# --- Aplicação ---
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_USE_AT_LEAST_64_RANDOM_CHARS
APP_ALLOWED_HOSTS=["http://localhost:3000","http://localhost:8000"]
APP_DEBUG=false

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=officejoe
POSTGRES_USER=officejoe_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://officejoe_user:CHANGE_ME_STRONG_PASSWORD@db:5432/officejoe

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO / S3 ---
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET_DOCUMENTS=officejoe-documents
MINIO_BUCKET_EXPORTS=officejoe-exports
MINIO_SECURE=false

# --- OCR ---
OCR_ENGINE=paddleocr          # paddleocr | tesseract | auto
OCR_LANGUAGE=por+eng
OCR_DPI=300
OCR_MAX_PAGES_PER_TASK=50     # Chunks de páginas por tarefa Celery
OCR_CONFIDENCE_THRESHOLD=0.6

# --- IA / Embeddings ---
AI_PROVIDER=anthropic          # anthropic | openai | local
ANTHROPIC_API_KEY=CHANGE_ME
OPENAI_API_KEY=CHANGE_ME
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_DIMENSIONS=1536

# --- pgvector / Qdrant ---
VECTOR_BACKEND=pgvector        # pgvector | qdrant
QDRANT_URL=http://qdrant:6333

# --- Email (notificações) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=OfficeJoe <noreply@example.com>

# --- Segurança ---
MAX_UPLOAD_SIZE_MB=500
ALLOWED_UPLOAD_EXTENSIONS=["pdf"]
BCRYPT_ROUNDS=12
