# ============================================================
# OfficeJoe – Plataforma de Perícias Contábeis
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Altere os valores CHANGE_ME com suas configurações
# 3. Em produção, NUNCA versione o arquivo .env
# 4. Use variáveis de ambiente seguras
#
# Para desenvolvimento local, os valores padrão funcionam.
# ============================================================

# --- Aplicação ---
APP_ENV=development
APP_TITLE=OfficeJoe API
APP_VERSION=0.1.0
APP_SECRET_KEY=change_me_to_a_random_string_with_at_least_64_characters_DO_NOT_USE_IN_PROD
APP_ALLOWED_HOSTS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8000","http://127.0.0.1:8000"]
APP_DEBUG=true

# --- JWT (Autenticação) ---
JWT_SECRET_KEY=change_me_to_a_different_random_string_with_at_least_64_characters_DO_NOT_USE_IN_PROD
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=officejoe
POSTGRES_USER=officejoe_user
POSTGRES_PASSWORD=postgres_dev_password
DATABASE_URL=postgresql+asyncpg://officejoe_user:postgres_dev_password@db:5432/officejoe

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO / S3 (Storage) ---
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=officejoe-documents
MINIO_BUCKET_EXPORTS=officejoe-exports
MINIO_SECURE=false

# --- OCR (Processamento de Documentos) ---
OCR_ENGINE=paddleocr          # Opções: paddleocr | tesseract | auto
OCR_LANGUAGE=por+eng          # Português + Inglês
OCR_DPI=300
OCR_MAX_PAGES_PER_TASK=50     # Quantas páginas processar por tarefa Celery
OCR_CONFIDENCE_THRESHOLD=0.6

# --- IA / Embeddings (Análise com IA) ---
AI_PROVIDER=anthropic          # Opções: anthropic | openai | local
ANTHROPIC_API_KEY=sk-ant-change-me-to-your-real-key
OPENAI_API_KEY=sk-change-me-to-your-real-key
AI_MODEL=claude-opus-4-7
AI_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_DIMENSIONS=1536

# --- Vector Database ---
VECTOR_BACKEND=pgvector        # Opções: pgvector | qdrant
QDRANT_URL=http://qdrant:6333

# --- Email (Notificações) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=OfficeJoe <noreply@example.com>
SMTP_TLS=true

# --- Segurança ---
MAX_UPLOAD_SIZE_MB=500
ALLOWED_UPLOAD_EXTENSIONS=["pdf"]
BCRYPT_ROUNDS=12

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | text

# --- Features (Toggle) ---
ENABLE_OCR=true
ENABLE_AI=true
ENABLE_VECTOR_SEARCH=true
ENABLE_NOTIFICATIONS=false
